# Vercel → Settings → Environment Variables

# Canonical site URL — must match your Vercel primary domain (www or apex, not both)
NEXT_PUBLIC_SITE_URL=https://www.vokal.work

# API (Railway)
NEXT_PUBLIC_VOCA_API_URL=https://your-api.up.railway.app
VOCA_API_URL=https://your-api.up.railway.app

# Google Analytics 4 — landing page only
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase — optional on frontend (Studio auth uses API JWT now)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
