# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (required)
OPENAI_API_KEY=sk-...
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Deepgram (recommended STT — falls back to Whisper if unset)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# Resend (optional — waitlist + weekly insights)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Vokal <info@vokal.work>
NOTIFY_EMAIL=info@vokal.work

# Redis (optional — caching + rate limits; in-memory fallback if unset)
REDIS_URL=redis://localhost:6379

# Pinecone (optional — vector memory for voice sessions)
PINECONE_API_KEY=
PINECONE_INDEX=vokal-voice

# Cron secret — optional manual trigger for POST /api/v1/cron/weekly-insights
CRON_SECRET=your-random-secret

# Delivery / connections
APP_FRONTEND_URL=https://vokal.work
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=

# Gmail OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api.up.railway.app/api/v1/connections/oauth/gmail/callback

# Notion OAuth (https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://your-api.up.railway.app/api/v1/connections/oauth/notion/callback

# Weekly insights — runs automatically inside the API (no external cron needed)
WEEKLY_INSIGHTS_ENABLED=true
WEEKLY_INSIGHTS_DAY=mon
WEEKLY_INSIGHTS_HOUR=9

# CORS — include your production domain
CORS_ORIGINS=https://vokal.work,https://www.vokal.work,http://localhost:3000

PORT=3001
