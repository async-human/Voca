# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (optional — emails on signup)
# Verify your domain in Resend first. FROM address must use that verified domain
# (e.g. info@vokal.com if vokal.com is verified, or info@vokal.work if vokal.work is verified).
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Vokal <info@vokal.com>
NOTIFY_EMAIL=info@vokal.com

# Comma-separated frontend URLs (production + preview + local)
CORS_ORIGINS=https://vokal.work,https://www.vokal.work,http://localhost:3000

# Railway sets PORT automatically
PORT=3001
