# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (optional — welcome email on signup)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Voca <hello@usevoca.com>

# Comma-separated frontend URLs (Vercel production + preview + local)
CORS_ORIGINS=https://usevoca.com,https://www.usevoca.com,http://localhost:3000

# Railway sets PORT automatically
PORT=3001
