# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (optional — emails on signup)
# Verify vokal.work in Resend first. FROM and NOTIFY must use that domain.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Vokal <info@vokal.work>
NOTIFY_EMAIL=info@vokal.work

# Comma-separated frontend URLs (production + preview + local)
CORS_ORIGINS=https://vokal.work,https://www.vokal.work,http://localhost:3000

# Railway sets PORT automatically
PORT=3001
