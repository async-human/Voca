# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (optional — welcome email on signup)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Voca <hello@vokal.work>

# Comma-separated frontend URLs (production + preview + local)
CORS_ORIGINS=https://vokal.work,https://www.vokal.work,http://localhost:3000

# Railway sets PORT automatically
PORT=3001
