# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (required for voice → polish flow)
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_GENERATION_MODEL=gpt-4o-mini

# Resend (optional — emails on waitlist signup)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Vokal <info@vokal.work>
NOTIFY_EMAIL=info@vokal.work

# Comma-separated frontend URLs
CORS_ORIGINS=https://vokal.work,https://www.vokal.work,http://localhost:3000

# Railway sets PORT automatically
PORT=3001
